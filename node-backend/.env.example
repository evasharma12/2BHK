# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=2bhk_db
DB_PORT=3306
# Railway / some hosts also expose MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT

# Set to true to skip CREATE TABLE / migrations at server startup (run `node storage/createTables.js` manually instead)
# SKIP_DB_SCHEMA_ON_START=false

# JWT, Google OAuth, etc. (see your deployment)

# Public URL for links in emails (chat digest CTA). Comma-separated FRONTEND_URL uses first host.
APP_PUBLIC_URL=http://localhost:3000
# FRONTEND_URL=http://localhost:3000

# SMTP (also used for chat digest “from”; digest skips sending if host/user/pass missing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SUPPORT_NOTIFICATION_FROM=
SUPPORT_NOTIFICATION_TO=

# Chat unread email digest (daily cron inside server.js via node-cron)
# Master switch: digest runner and cron registration are no-ops unless this is exactly "true"
CHAT_DIGEST_ENABLED=false
# Cron expression (default 09:00 daily, server local time unless TZ env is set on the host)
CHAT_DIGEST_CRON=0 9 * * *
